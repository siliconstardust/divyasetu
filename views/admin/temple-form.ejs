<%- include('../partials/header') %>

<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-brand"><span>🕉</span><h2>Admin Panel</h2></div>
        <nav class="admin-nav">
            <a href="/admin" class="admin-nav-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <a href="/admin/temples" class="admin-nav-link active"><i class="fas fa-place-of-worship"></i> Temples</a>
            <a href="/admin/bookings" class="admin-nav-link"><i class="fas fa-calendar-check"></i> Bookings</a>
            <a href="/admin/users" class="admin-nav-link"><i class="fas fa-users"></i> Users</a>
            <a href="/" class="admin-nav-link"><i class="fas fa-globe"></i> View Site</a>
            <a href="/auth/logout" class="admin-nav-link logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>

    <div class="admin-main">
        <div class="admin-topbar">
            <h1><%= temple ? 'Edit Temple' : 'Add New Temple' %></h1>
            <a href="/admin/temples" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <div class="form-card" style="max-width:700px">
            <form action="<%= temple ? '/admin/temples/' + temple.id : '/admin/temples' %>"
                  method="POST" enctype="multipart/form-data" id="templeForm">

                <div class="form-row">
                    <div class="form-group">
                        <label>Temple Name *</label>
                        <input type="text" name="name" value="<%= temple ? temple.name : '' %>" required>
                    </div>
                    <div class="form-group">
                        <label>Deity / Presiding God *</label>
                        <input type="text" name="deity" value="<%= temple ? temple.deity : '' %>" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Location *</label>
                    <input type="text" name="location" value="<%= temple ? temple.location : '' %>"
                           placeholder="City, State" required>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" rows="5" placeholder="Describe the temple's history, significance..."><%= temple ? temple.description : '' %></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Capacity (per slot)</label>
                        <input type="number" name="capacity" value="<%= temple ? temple.capacity : 50 %>" min="1" max="5000">
                    </div>
                    <% if (temple) { %>
                    <div class="form-group">
                        <label>Active Status</label>
                        <label class="toggle-switch">
                            <input type="checkbox" name="is_active" <%= temple.is_active ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span class="toggle-label">Temple is active</span>
                        </label>
                    </div>
                    <% } %>
                </div>

                <div class="form-group">
                    <label>Temple Image URL</label>
                    <input type="text" name="image_url" id="imageUrl"
                           value="<%= temple ? temple.image_url : '' %>"
                           placeholder="https://..." oninput="previewFromUrl(this.value)">
                </div>

                <div class="form-group">
                    <label>— OR Upload Image File</label>
                    <input type="file" name="image" accept="image/jpeg,image/png,image/webp"
                           onchange="previewFile(this)">
                </div>

                <!-- Image Preview -->
                <div id="imgPreview" style="margin-bottom:1.5rem;display:<%= temple && temple.image_url ? 'block' : 'none' %>">
                    <p style="font-size:0.85rem;color:#888;margin-bottom:0.5rem">Image Preview:</p>
                    <img id="previewImg" src="<%= temple ? temple.image_url : '' %>"
                         style="max-width:100%;max-height:200px;border-radius:10px;object-fit:cover;"
                         onerror="this.style.display='none'">
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> <%= temple ? 'Update Temple' : 'Add Temple' %>
                    </button>
                    <a href="/admin/temples" class="btn btn-outline btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function previewFromUrl(url) {
    if (url) {
        document.getElementById('previewImg').src = url;
        document.getElementById('imgPreview').style.display = 'block';
    }
}
function previewFile(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('previewImg').src = e.target.result;
            document.getElementById('imgPreview').style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>

<%- include('../partials/footer') %>

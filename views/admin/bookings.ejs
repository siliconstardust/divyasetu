<%- include('../partials/header') %>

<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-brand"><span>🕉</span><h2>Admin Panel</h2></div>
        <nav class="admin-nav">
            <a href="/admin" class="admin-nav-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <a href="/admin/temples" class="admin-nav-link"><i class="fas fa-place-of-worship"></i> Temples</a>
            <a href="/admin/bookings" class="admin-nav-link active"><i class="fas fa-calendar-check"></i> Bookings</a>
            <a href="/admin/users" class="admin-nav-link"><i class="fas fa-users"></i> Users</a>
            <a href="/" class="admin-nav-link"><i class="fas fa-globe"></i> View Site</a>
            <a href="/auth/logout" class="admin-nav-link logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>

    <div class="admin-main">
        <div class="admin-topbar">
            <h1>All Bookings</h1>
            <span class="badge-count"><%= bookings.length %> total</span>
        </div>

        <!-- Filter by status -->
        <div class="admin-filter-bar">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="confirmed">Confirmed</button>
            <button class="filter-btn" data-filter="cancelled">Cancelled</button>
            <button class="filter-btn" data-filter="pending">Pending</button>
        </div>

        <div class="admin-table-section">
            <div class="table-wrap">
                <table class="data-table" id="bookingsTable">
                    <thead>
                        <tr>
                            <th>Ref</th>
                            <th>User</th>
                            <th>Temple</th>
                            <th>Date</th>
                            <th>Slot</th>
                            <th>Persons</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% bookings.forEach(b => { %>
                        <tr data-status="<%= b.status %>">
                            <td><code><%= b.booking_ref %></code></td>
                            <td>
                                <strong><%= b.user_name %></strong><br>
                                <small><%= b.email %></small>
                            </td>
                            <td><%= b.temple_name %></td>
                            <td><%= new Date(b.booking_date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
                            <td><%= b.time_slot %></td>
                            <td><%= b.persons %></td>
                            <td><span class="status-badge <%= b.status %>"><%= b.status %></span></td>
                            <td>
                                <form action="/admin/bookings/<%= b.id %>/status" method="POST" style="display:flex;gap:0.4rem">
                                    <select name="status" class="select-sm">
                                        <option value="confirmed" <%= b.status==='confirmed'?'selected':'' %>>Confirmed</option>
                                        <option value="cancelled" <%= b.status==='cancelled'?'selected':'' %>>Cancelled</option>
                                        <option value="pending"   <%= b.status==='pending'  ?'selected':'' %>>Pending</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline">
                                        <i class="fas fa-save"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const filter = this.dataset.filter;
        document.querySelectorAll('#bookingsTable tbody tr').forEach(row => {
            row.style.display = (filter === 'all' || row.dataset.status === filter) ? '' : 'none';
        });
    });
});
</script>

<%- include('../partials/footer') %>

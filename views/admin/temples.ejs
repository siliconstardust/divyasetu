<%- include('../partials/header') %>

<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-brand"><span>🕉</span><h2>Admin Panel</h2></div>
        <nav class="admin-nav">
            <a href="/admin" class="admin-nav-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <a href="/admin/temples" class="admin-nav-link active"><i class="fas fa-place-of-worship"></i> Temples</a>
            <a href="/admin/bookings" class="admin-nav-link"><i class="fas fa-calendar-check"></i> Bookings</a>
            <a href="/admin/users" class="admin-nav-link"><i class="fas fa-users"></i> Users</a>
            <a href="/" class="admin-nav-link"><i class="fas fa-globe"></i> View Site</a>
            <a href="/auth/logout" class="admin-nav-link logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>

    <div class="admin-main">
        <div class="admin-topbar">
            <h1>Manage Temples</h1>
            <a href="/admin/temples/new" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Temple
            </a>
        </div>

        <div class="admin-table-section">
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Location</th>
                            <th>Deity</th>
                            <th>Capacity</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% temples.forEach(t => { %>
                        <tr>
                            <td>
                                <img src="<%= t.image_url %>" alt="<%= t.name %>"
                                     style="width:60px;height:45px;object-fit:cover;border-radius:6px;"
                                     onerror="this.src='/images/temple-placeholder.svg'">
                            </td>
                            <td><strong><%= t.name %></strong></td>
                            <td><%= t.location %></td>
                            <td><%= t.deity %></td>
                            <td><%= t.capacity %></td>
                            <td>
                                <span class="status-badge <%= t.is_active ? 'confirmed' : 'cancelled' %>">
                                    <%= t.is_active ? 'Active' : 'Inactive' %>
                                </span>
                            </td>
                            <td class="action-btns">
                                <a href="/admin/temples/<%= t.id %>/edit" class="btn btn-sm btn-outline">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <form action="/admin/temples/<%= t.id %>/delete" method="POST" style="display:inline"
                                      onsubmit="return confirm('Delete this temple?')">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

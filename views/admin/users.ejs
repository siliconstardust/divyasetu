<%- include('../partials/header') %>

<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-brand"><span>🕉</span><h2>Admin Panel</h2></div>
        <nav class="admin-nav">
            <a href="/admin" class="admin-nav-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <a href="/admin/temples" class="admin-nav-link"><i class="fas fa-place-of-worship"></i> Temples</a>
            <a href="/admin/bookings" class="admin-nav-link"><i class="fas fa-calendar-check"></i> Bookings</a>
            <a href="/admin/users" class="admin-nav-link active"><i class="fas fa-users"></i> Users</a>
            <a href="/" class="admin-nav-link"><i class="fas fa-globe"></i> View Site</a>
            <a href="/auth/logout" class="admin-nav-link logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>

    <div class="admin-main">
        <div class="admin-topbar">
            <h1>All Users</h1>
            <span class="badge-count"><%= users.length %> registered</span>
        </div>

        <div class="admin-table-section">
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Bookings</th>
                            <th>Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u => { %>
                        <tr>
                            <td>#<%= u.id %></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:0.5rem">
                                    <span class="user-avatar sm"><%= u.name.charAt(0).toUpperCase() %></span>
                                    <strong><%= u.name %></strong>
                                </div>
                            </td>
                            <td><%= u.email %></td>
                            <td>
                                <span class="status-badge <%= u.role === 'admin' ? 'admin-badge' : 'confirmed' %>">
                                    <%= u.role %>
                                </span>
                            </td>
                            <td><%= u.booking_count %></td>
                            <td><%= new Date(u.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
